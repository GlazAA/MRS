{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run MRS (Windows MAUI)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "src/MRS.Maui/MRS.Maui.csproj",
        "-f",
        "net9.0-windows10.0.19041.0"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
